generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  title         String      @default("Untitled Recording")
  status        String      @default("RECORDING")
  duration      Int?
  language      String      @default("id")
  audioUrl      String?
  transcript    String?
  summary       Json?
  keyPoints     String[]
  mindMap       Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}
